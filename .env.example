TOKEN=your_bot_token_here

# Localization: ru_RU or en_US
LOCALE=ru_RU

# Path to SQLite database
DB_PATH=users.db

# Code entry attempts before temp-block
MAX_ATTEMPTS=3

# Temp-block duration in seconds (default 15 min)
COOL_DOWN=900

# Comma-separated Telegram user IDs to permanently ban on join
# Example: BLOCKLIST=123456789,987654321
BLOCKLIST=

# Web server settings
# Use 0.0.0.0 when running inside Docker
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Base URL used to build captcha links sent to users
CAPTCHA_BASE_URL=https://yourdomain.com/captcha

# Captcha link lifetime in seconds (default 5 min)
CAPTCHA_TIMEOUT=300

# Number of enemies to kill in the DOOM captcha
CAPTCHA_ENEMIES=4

# Minimum seconds the page must be open before completion is accepted
MIN_PLAY_TIME=3.0

# Minimum seconds between registered kills (prevents scripted rapid kills)
KILL_COOLDOWN=0.5
