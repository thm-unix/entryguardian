TOKEN=your_bot_token_here

# Localization: ru_RU or en_US
LOCALE=ru_RU

# Path to TTF font for CAPTCHA images
FONT_PATH=/usr/share/fonts/TTF/SimpleHandmade.ttf

# CAPTCHA image settings
FONT_SIZE=144
PIC_WIDTH=300
PIC_HEIGHT=140
NOISE_LEVEL=30
NOISE_COLOR=black

# Verification settings
MAX_ATTEMPTS=3
COOL_DOWN=900

# Path to SQLite database
DB_PATH=users.db

# Comma-separated Telegram user IDs to permanently ban on join
# Example: BLOCKLIST=123456789,987654321
BLOCKLIST=
